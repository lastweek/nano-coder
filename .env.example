# LLM Provider Configuration
# Options: openai, azure, ollama, custom
LLM_PROVIDER=custom

# API Key (env var name depends on provider)
# For OpenAI: OPENAI_API_KEY
# For Azure: AZURE_API_KEY
# For Ollama: (no API key needed)
# For custom: CUSTOM_API_KEY
CUSTOM_API_KEY=your-api-key-here

# Base URL (optional, for custom/ollama/azure endpoints)
# Examples:
# - Ollama: http://localhost:11434/v1
# - Azure: https://your-resource.openai.azure.com
# - Custom: https://your-api-endpoint.com
# Leave empty for default OpenAI
BASE_URL=https://api.z.ai/api/paas/v4/

# Model name (default depends on provider)
# OpenAI: gpt-4, gpt-3.5-turbo, etc.
# Ollama: llama2, codellama, mistral, etc.
# Azure: your deployment name
MODEL=glm-5

# Optional: Max conversation history
MAX_CONVERSATION_HISTORY=50

# Enable chat completion logging (true/false)
# Logs all LLM requests/responses and tool executions to logs/ directory
ENABLE_LOGGING=true

# Log directory (optional, defaults to "logs")
# LOG_DIR=logs
